{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://mahatathastu.com"
  },
  "functions": {
    "src/app/api/noxatra/route.ts": { "maxDuration": 60 },
    "src/app/api/noxatra/section/route.ts": { "maxDuration": 60 },
    "src/app/api/groq/route.ts": { "maxDuration": 60 },
    "src/app/api/payment/route.ts": { "maxDuration": 30 },
    "src/app/api/itinerary/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/spiritual-digest/route.ts": { "maxDuration": 60 },
    "src/app/api/reports/[reportId]/pdf/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/spiritual-digest",
      "schedule": "0 6 */3 * *"
    }
  ]
}
